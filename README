1. Template CloudForm de SNS Topic dans le repertoire: template-cf-sns-topic
2. Template SAM de app-slack dans: sam-app-slack
3. Template SAM pour le producer de log subscription: log-subscription/sam-app-sns-producer-log-subscription-error
4. Template CloudForm pour log subscription: log-subscription/template-cf-log-subscription-filter-error




# DEPLOIEMENT
Créer l'environnement virtuel
Installer les dépendances

# 1. DEPLOYER SNS TOPIC
   cd template-cf-sns-topic
   aws cloudformation deploy \
    --template-file stack-sns-topic_put_lambda_slack.yaml \
    --stack-name stack-log-alarm-sns-topic-dev-mgitservice \
    --parameter-overrides SnsTopicName=log-alarm-sns-topic-dev-mgitservice client=mgitservice EnvironmentName=dev \
    --region eu-west-1 \
    --profile 879381257984_AWS-Sandbox-AdminAccess

# 2. DEPLOYER SAM ENVOYER MESSAGE SNS vers SLACK
   cd ../sam-app-slack
   sam build
   sam deploy --config-env dev

# 3. DEPLOYER SAM (ENVOIE DES MESSAGE D'ALARM) PRODUCER DE SNS
   cd ../alarms_app_sam
   sam build
   sam deploy --config-env dev

# 4. DEPLOYER UN LOG ALARM (BREACHING LOG)
   cd ../template-cf-log-alarm
   aws cloudformation deploy \
    --template-file stack-log-alarm.yaml \
    --stack-name stack-log-alarm-putlog-dev-mgitservice \
    --parameter-overrides LogGroupName=/mgitservice/dev/putlog client=mgitservice PeriodAlarm=300 EnvironmentName=dev \
    --region eu-west-1 \
    --profile 879381257984_AWS-Sandbox-AdminAccess

# 5. DEPLOYER UN ALARM SQS (THRESHOLD)
   cd ../template-sqs-alarm
   aws cloudformation deploy \
    --template-file stack-sqs-alarm.yaml \
    --stack-name stack-sqs-alarm-putlog-dev-mgitservice \
    --parameter-overrides QueueName=/mgitservice-dev-putlog client=mgitservice ThresholdMessages=100 EnvironmentName=dev \
    --region eu-west-1 \
    --profile 879381257984_AWS-Sandbox-AdminAccess

# 6. DEPLOYER SAM PRODUCER SUBSCRIPTION FILTER
   cd ../log-subscription/sam-app-sns-producer-log-subscription-error
   sam build
   sam deploy --config-env dev

# 7. DEPLOYER CLOUDFORMATION LOG SUBSCRIPTION FILTER
   cd ../template-cf-log-subscription-filter-error
   aws cloudformation deploy \
    --template-file template-log-subscription.yaml \
    --stack-name stack-log-subscription-putlog-dev-mgitservice \
    --parameter-overrides LogGroupName=/mgitservice/dev/putlog client=mgitservice patternFilter=ERROR EnvironmentName=dev \
    --region eu-west-1 \
    --profile 879381257984_AWS-Sandbox-AdminAccess

# SUPPRESSION


# 1. LOG GROUP SUBSCRIPTION
aws cloudformation delete-stack \
    --stack-name stack-log-subscription-putlog-dev-mgitservice \
    --region eu-west-1 \
    --profile 879381257984_AWS-Sandbox-AdminAccess

# 2. LOG ALARM
aws cloudformation delete-stack \
    --stack-name stack-log-alarm-putlog-dev-mgitservice \
    --region eu-west-1 \
    --profile 879381257984_AWS-Sandbox-AdminAccess


# 3. APP SNS PRODUCER LOG ALARM
cd log-alarm/sam-app-sns-producer-log-alarm
sam delete --config-env dev --no-prompts

# 4. APP SNS PRODUCER SUBSCRIPTION
cd ../sam-app-sns-producer-log-subscription
sam delete --config-env dev --no-prompts

# 5. APP SLACK
cd ../sam-app-slack
sam delete --config-env dev --no-prompts

# 6. SNS TOPIC
aws cloudformation delete-stack \
    --stack-name stack-log-alarm-sns-topic-dev \
    --region eu-west-1 \
    --profile 879381257984_AWS-Sandbox-AdminAccess